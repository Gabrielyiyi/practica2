<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Login - Repositorio de Películas</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .login-card {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 350px;
            text-align: center;
        }
        .login-card h1 { margin-top: 0; color: #2c3e50; font-size: 24px; }
        .form-group { margin-bottom: 20px; text-align: left; }
        .form-group label { display: block; margin-bottom: 8px; color: #333; font-weight: bold; font-size: 14px; }
        .form-group input { 
            width: 100%; 
            padding: 10px; 
            border: 1px solid #ccc; 
            border-radius: 5px; 
            box-sizing: border-box; 
            font-size: 14px;
        }
        .form-group input:focus { border-color: #3498db; outline: none; }
        .btn-login { 
            width: 100%; 
            padding: 12px; 
            background: #2c3e50; 
            color: white; 
            border: none; 
            border-radius: 5px; 
            cursor: pointer; 
            font-size: 16px; 
            font-weight: bold; 
            transition: background 0.3s;
        }
        .btn-login:hover { background: #1a252f; }
        .error-msg { 
            color: #c0392b; 
            background: #fadbd8; 
            padding: 10px; 
            border-radius: 5px; 
            margin-bottom: 20px; 
            font-size: 14px;
            border: 1px solid #e74c3c;
        }
        .register-link { margin-top: 20px; font-size: 14px; }
        .register-link a { color: #2980b9; text-decoration: none; font-weight: bold; }
        .register-link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="login-card">
        <h1>🎬 Iniciar Sesión</h1>
        
        <!-- Si Passport.js nos manda un error desde el servidor (ej. "Contraseña incorrecta"), lo inyectamos aquí -->
        <% if (typeof error !== 'undefined') { %>
            <div class="error-msg">⚠️ <%= error %></div>
        <% } %>
        
        <!-- Formulario: Envia los datos usando el método POST (oculto en la URL) a la ruta /login -->
        <form action="/login" method="POST">
            <div class="form-group">
                <label>Usuario:</label>
                <!-- El 'name' debe coincidir exactamente con lo que Passport espera leer -->
                <input type="text" name="username" placeholder="Ingresa tu usuario" required>
            </div>
            <div class="form-group">
                <label>Contraseña:</label>
                <input type="password" name="password" placeholder="Ingresa tu contraseña" required>
            </div>
            <button type="submit" class="btn-login">Entrar al Catálogo</button>
        </form>
        
        <div class="register-link">
            ¿No tienes cuenta? <a href="/register">Regístrate aquí</a>
        </div>
    </div>
</body>
</html>